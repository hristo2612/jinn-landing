---
/**
 * Text chip row - the app's engine-pill treatment: text on --fill-tertiary,
 * no borders, no logos (§01 engine row, §08 dashboard surface row).
 */
interface Props {
  chips: readonly string[];
  /** Mono voice for the §08 dashboard surface chips. */
  mono?: boolean;
  centered?: boolean;
}

const { chips, mono = false, centered = false } = Astro.props;
---

<p
  class:list={[
    "chip-row",
    mono && "chip-row--mono",
    centered && "chip-row--centered",
  ]}
>
  {chips.map((chip) => <span class="chip-row__chip">{chip}</span>)}
</p>

<style>
  .chip-row {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin: var(--space-6) 0 0;
  }

  .chip-row--centered {
    justify-content: center;
  }

  .chip-row__chip {
    display: inline-flex;
    align-items: center;
    height: 30px;
    padding: 0 13px;
    border-radius: 999px;
    background: var(--fill-tertiary);
    color: var(--text-secondary);
    font-size: 12.5px;
    font-weight: var(--weight-semibold);
    white-space: nowrap;
  }

  .chip-row--mono .chip-row__chip {
    font-family: var(--font-code);
    font-size: 11.5px;
    font-weight: var(--weight-medium);
  }
</style>
