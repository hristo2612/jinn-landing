---
/**
 * Shared SVG icon sprite for the scene windows. Rendered ONCE per page so any
 * number of SceneWindow instances (A-07 stacks several on mobile) reference the
 * same symbol ids with no duplicate-id collisions. Icons mirror the real
 * dashboard's Lucide vocabulary; A-08 may swap this for the Lucide Astro
 * package without changing the `#i-*` reference contract.
 */
---

<svg width="0" height="0" class="scene-sprite" aria-hidden="true">
  <defs>
    <symbol id="i-msg" viewBox="0 0 24 24"
      ><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"
      ></path></symbol
    >
    <symbol id="i-users" viewBox="0 0 24 24"
