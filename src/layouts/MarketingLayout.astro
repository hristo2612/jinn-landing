---
import hankenVariableFont from "@fontsource-variable/hanken-grotesk/files/hanken-grotesk-latin-wght-normal.woff2?url";
import SiteNav from "../components/chrome/SiteNav.astro";
import "../styles/global.css";
import "../styles/scene-system.css";

interface Props {
  page?: "home" | "features" | "not-found";
  title?: string;
  description?: string;
  indexable?: boolean;
  /**
   * Root theme. The landing owns the site's one theatrical dark→light arc;
   * the features page is statically light, end to end
   * (STORYBOARD-FEATURES §5).
   */
  theme?: "dark" | "light";
}

const {
  page = "home",
  title = "Jinn - Run your own AI company",
  description = "Jinn is an open-source, local-first platform for running your own AI company. Hire AI employees, hand them real work, and approve what matters.",
  indexable = true,
  theme = "dark",
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;
const ogImageUrl = new URL("/og.png", Astro.site).href;
---

<!doctype html>
<html lang="en" data-theme={theme}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    {
      indexable ? (
        <link rel="canonical" href={canonicalUrl} />
      ) : (
        <meta name="robots" content="noindex,follow" />
      )
    }
    {
      /*
      The 🧞 brand (AMENDMENT §3): the SVG favicon renders the platform's
      own emoji glyph (matching the app's emoji favicon); the PNG fallbacks
      and apple-touch-icon are derived from Noto Emoji's genie - Apple's
      emoji artwork is never rasterized into this public repo.
    */
    }
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon-32.png" type="image/png" sizes="32x32" />
    <link rel="icon" href="/favicon-64.png" type="image/png" sizes="64x64" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Jinn" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    {indexable && <meta property="og:url" content={canonicalUrl} />}
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:alt" content={title} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={ogImageUrl} />
    <link
      rel="preload"
      href={hankenVariableFont}
      as="font"
      type="font/woff2"
      crossorigin="anonymous"
    />
    <title>{title}</title>
    <script is:inline>
      // Resolve motion before first paint so scene markup never flashes from
      // its static proof into a second visual state.
      document.documentElement.dataset.motion = window.matchMedia(
        "(prefers-reduced-motion: reduce)",
      ).matches
        ? "reduce"
        : "ok";
      document.documentElement.dataset.sceneRuntime =
        document.documentElement.dataset.motion === "ok"
          ? "loading"
          : "reduced";
    </script>
  </head>
  <body data-page={page}>
    <SiteNav currentPage={page === "features" ? "features" : "home"} />
    <slot />
    <script>
      import { installThemeTransition } from "../lib/theme-transition";

      installThemeTransition();
    </script>
  </body>
</html>
